    check-thresholds:
      needs: [deploy-production, rolling-average]
      runs-on: ubuntu-latest
      steps:
        - name: Check thresholds
          id: check
          run: |
            duration=${{ needs.deploy-production.outputs.deploy_duration }}
            avg=${{ needs.rolling-average.outputs.rolling_avg }}
            env="production"   # or "staging" depending on job context
            alert="false"

            if [ "$env" = "production" ]; then
              if [ "$duration" -gt 120 ]; then alert="true"; fi
              if (( $(echo "$avg > 90" | bc -l) )); then alert="true"; fi
            elif [ "$env" = "staging" ]; then
              if [ "$duration" -gt 180 ]; then alert="true"; fi
              if (( $(echo "$avg > 150" | bc -l) )); then alert="true"; fi
            fi

            echo "alert=$alert" >> $GITHUB_OUTPUT
            echo "env=$env" >> $GITHUB_OUTPUT

    notify-slow-slack:
      needs: check-thresholds
      if: needs.check-thresholds.outputs.alert == 'true'
      runs-on: ubuntu-latest
      steps:
        - name: Notify Slack
          run: |
            curl -X POST -H 'Content-type: application/json' \
            --data '{
              "text": "⚠️ Slow deploy detected in ${{ needs.check-thresholds.outputs.env }}. Duration: ${{ needs.deploy-production.outputs.deploy_duration }}s (avg last 5: ${{ needs.rolling-average.outputs.rolling_avg }}s)"
            }' \
            https://hooks.slack.com/services/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

    notify-slow-teams:
      needs: check-thresholds
      if: needs.check-thresholds.outputs.alert == 'true'
      runs-on: ubuntu-latest
      steps:
        - name: Notify Teams
          run: |
            curl -H 'Content-Type: application/json' \
            -d '{
              "@type": "MessageCard",
              "@context": "http://schema.org/extensions",
              "summary": "Slow Deployment Alert",
              "themeColor": "FFA500",
              "title": "⚠️ Slow deploy in ${{ needs.check-thresholds.outputs.env }}",
              "sections": [{
                "facts": [
                  { "name": "Duration", "value": "${{ needs.deploy-production.outputs.deploy_duration }}s" },
                  { "name": "Rolling Avg (last 5)", "value": "${{ needs.rolling-average.outputs.rolling_avg }}s" },
                  { "name": "Workflow Run", "value": "https://github.com/${{ github.repository }}/actions/runs/${{ github.run_id }}" }
                ]
              }]
            }' \
            ${{ secrets.TEAMS_WEBHOOK_URL }}
  failure-summary:
    if: failure()
    runs-on: ubuntu-latest
    needs: [jest-tests, cypress-tests, build, deploy-staging, deploy-production]
    steps:
      - name: Generate failure list
        id: summary
        run: |
          echo "jobs_failed=" >> $GITHUB_OUTPUT
          for job in jest-tests cypress-tests build deploy-staging deploy-production; do
            if [ "${{ needs[$job].result }}" == "failure" ]; then
              echo "- $job" >> failed.txt
            fi
          done
          echo "jobs_failed=$(cat failed.txt)" >> $GITHUB_OUTPUT

  notify-failure-slack:
    needs: failure-summary
    runs-on: ubuntu-latest
    steps:
      - name: Notify Slack of Failures
        run: |
          curl -X POST -H 'Content-type: application/json' \
          --data '{
            "blocks": [
              {
                "type": "section",
                "text": {
                  "type": "mrkdwn",
                  "text": "❌ *Workflow failed!*"
                }
              },
              {
                "type": "section",
                "text": {
                  "type": "mrkdwn",
                  "text": "Failed jobs:\n${{ steps.summary.outputs.jobs_failed }}"
                }
              },
              {
                "type": "section",
                "text": {
                  "type": "mrkdwn",
                  "text": "View run: <https://github.com/${{ github.repository }}/actions/runs/${{ github.run_id }}|Workflow Run>"
                }
              }
            ]
          }' \
          https://hooks.slack.com/services/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

  notify-failure-teams:
    needs: failure-summary
    runs-on: ubuntu-latest
    steps:
      - name: Notify Teams of Failures
        run: |
          curl -H 'Content-Type: application/json' \
          -d '{
            "@type": "MessageCard",
            "@context": "http://schema.org/extensions",
            "summary": "Workflow Failures",
            "themeColor": "FF0000",
            "title": "❌ Workflow failed",
            "sections": [{
              "facts": [
                { "name": "Failed Jobs", "value": "${{ steps.summary.outputs.jobs_failed }}" },
                { "name": "Workflow Run", "value": "https://github.com/${{ github.repository }}/actions/runs/${{ github.run_id }}" }
              ]
            }]
          }' \
          ${{ secrets.TEAMS_WEBHOOK_URL }}
name: CI/CD - Jest, Cypress, Deploy (Staging & Production)

on:
  push:
    branches:
      - main
      - staging
  pull_request:

jobs:
  jest-tests:
    name: Jest Tests
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: npm
      - run: npm install
      - name: Run Jest
        run: npm test -- --ci

  cypress-tests:
    name: Cypress Tests (${{ matrix.os }} / Node ${{ matrix.node }} / ${{ matrix.browser }})
    needs: jest-tests
    strategy:
      fail-fast: false
      matrix:
        os: [ubuntu-latest, windows-latest, macos-latest]
        node: [16, 18, 20]
        browser: [chrome, firefox, edge, safari, brave]
    runs-on: ${{ matrix.os }}
    services:
      mysql:
        image: mysql:8
        env:
          MYSQL_ROOT_PASSWORD: root
          MYSQL_DATABASE: test_db
        ports:
          - 3306:3306
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-node@v4
        with:
          node-version: ${{ matrix.node }}
          cache: npm

      - uses: actions/cache@v4
        with:
          path: ~/.cache/Cypress
          key: cypress-${{ runner.os }}-${{ hashFiles('package-lock.json') }}
          restore-keys: |
            cypress-${{ runner.os }}-

      - run: npm install
      - run: npm run db:reset

      - uses: cypress-io/github-action@v6
        with:
          start: npm start
          wait-on: http://localhost:3000
          browser: ${{ matrix.browser }}
          record: true
          key: ${{ secrets.CYPRESS_RECORD_KEY }}
          parallel: true

      - name: Upload Cypress Artifacts
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: cypress-artifacts-${{ matrix.os }}-node-${{ matrix.node }}-${{ matrix.browser }}
          path: |
            cypress/screenshots
            cypress/videos
            cypress/logs

  deploy-staging:
    name: Deploy Staging
    needs: [jest-tests, cypress-tests]
    runs-on: ubuntu-latest
    environment:
      name: staging
    steps:
      - uses: actions/checkout@v4

      - name: Set environment
        run: echo "env=staging" >> $GITHUB_OUTPUT

      - name: Deploy to Staging (Vercel example)
        run: vercel --prod --token ${{ secrets.VERCEL_TOKEN }}

      - name: Notify Slack - Staging Live
        uses: slackapi/slack-github-action@v1.24.0
        with:
          payload: |
            {
              "blocks": [
                {
                  "type": "section",
                  "text": {
                    "type": "mrkdwn",
                    "text": "🚀 *Staging deployment complete!*"
                  }
                },
                {
                  "type": "divider"
                },
                {
                  "type": "section",
                  "fields": [
                    {
                      "type": "mrkdwn",
                      "text": "*Environment:* Staging"
                    },
                    {
                      "type": "mrkdwn",
                      "text": "*URL:* <https://your-staging-url.com|View Staging>"
                    },
                    {
                      "type": "mrkdwn",
                      "text": "*Workflow:* <${{ github.server_url }}/${{ github.repository }}/actions/runs/${{ github.run_id }}|View Run>"
                    }
                  ]
                },
                {
                  "type": "section",
                  "fields": [
                    {
                      "type": "mrkdwn",
                      "text": "*Triggered by:* <@${{ github.actor }}>"
                    },
                    {
                      "type": "mrkdwn",
                      "text": "*Commit:* <${{ github.server_url }}/${{ github.repository }}/commit/${{ github.sha }}|${{ github.sha }}>"
                    },
                    {
                      "type": "mrkdwn",
                      "text": "*Branch:* ${{ github.ref_name }}"
                    },
                    {
                      "type": "mrkdwn",
                      "text": "*Repository:* ${{ github.repository }}"
                    },
                    {
                      "type": "mrkdwn",
                      "text": "*Workflow:* <${{ github.server_url }}/${{ github.repository }}/actions/runs/${{ github.run_id }}|View Run>"
                    },
                    {
                      "type": "mrkdwn",
                      "text": "*Event Type:* ${{ github.event_name }}"
                    },
                    {
                      "type": "mrkdwn",
                      "text": "*Job Status:* ${{ job.status }}"
                    },
                    {
                      "type": "mrkdwn",
                      "text": "*Timestamp:* ${{ github.run_started_at }}"
                    }
                  ]
                },
                {
                  "type": "context",
                  "elements": [
                    {
                      "type": "mrkdwn",
                      "text": "For more details, see the workflow run link above."
                    }
                  ]
                }
              ]
            }
        steps:
          - uses: actions/checkout@v4

          - name: Set environment
            run: echo "env=staging" >> $GITHUB_OUTPUT

          - name: Deploy to Staging (Vercel example)
            run: vercel --prod --token ${{ secrets.VERCEL_TOKEN }}

          - name: Notify Slack - Staging Live
            uses: slackapi/slack-github-action@v1.24.0
            with:
              payload: |
                { ...existing code... }
            env:
              SLACK_WEBHOOK_URL: https://hooks.slack.com/services/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
                      }' \
                      "https://sheets.googleapis.com/v4/spreadsheets/YOUR_SHEET_ID/values/DeployDurations!A:E:append?valueInputOption=USER_ENTERED"

                - name: Log deploy duration
                  run: |
                    echo "${{ steps.duration.outputs.deploy_duration }}" >> durations.txt

                - name: Upload durations log
                  uses: actions/upload-artifact@v4
                  steps:
                    - uses: actions/checkout@v4

                    - name: Set environment
                      run: echo "env=production" >> $GITHUB_OUTPUT

                    - name: Deploy to Production (Vercel example)
                      run: vercel --prod --token ${{ secrets.VERCEL_TOKEN }}

                    - name: Notify Slack - Production Awaiting Approval
                      uses: slackapi/slack-github-action@v1.24.0
                      with:
                        payload: |
                          {
                            "text": "Production deployment is awaiting approval!"
                          }
                      steps:
                        - uses: actions/checkout@v4

                        - name: Set environment
                          run: echo "env=production" >> $GITHUB_OUTPUT

                        - name: Deploy to Production (Vercel example)
                          run: vercel --prod --token ${{ secrets.VERCEL_TOKEN }}

                        - name: Notify Slack - Production Awaiting Approval
                          uses: slackapi/slack-github-action@v1.24.0
                          with:
                            payload: |
                              { ...existing code... }
                          env:
                            SLACK_WEBHOOK_URL: ${{ secrets.SLACK_WEBHOOK_URL }}
              name: deploy-metrics
              path: deploy-metrics.csv
              retention-days: 30

          - name: Send deploy duration to Datadog
            run: |
              curl -X POST "https://api.datadoghq.com/api/v1/series" \
              -H "Content-Type: application/json" \
              -H "DD-API-KEY: ${{ secrets.DD_API_KEY }}" \
              -d '{
                "series": [{
                  "metric": "ci.deploy.duration",
                  "points": [[ '"$(date +%s)"', ${{ steps.duration.outputs.deploy_duration }} ]],
                  "tags": ["env:production","commit:${{ github.sha }}"]
                }]
              }'
    name: Deploy Production
    needs: deploy-staging
    runs-on: ubuntu-latest
    environment:
      name: production
      url: ${{ steps.deploy.outputs.url }}
    steps:
      - uses: actions/checkout@v4

      - name: Record start time
        id: start
        run: echo "start=$(date +%s)" >> $GITHUB_OUTPUT

      - name: Deploy to Production (Vercel example)
        id: deploy
        run: vercel --prod --token ${{ secrets.VERCEL_TOKEN }}

      - name: Record end time
        id: end
        run: echo "end=$(date +%s)" >> $GITHUB_OUTPUT

      - name: Calculate duration
        id: duration
        run: |
          duration=$(( ${{ steps.end.outputs.end }} - ${{ steps.start.outputs.start }} ))
          echo "deploy_duration=${duration}" >> $GITHUB_OUTPUT

      - name: Notify Slack - Production Awaiting Approval
        uses: slackapi/slack-github-action@v1.24.0
        with:
          payload: |
            {
              "text": "Production deployment is awaiting approval!"
            }
        env:
          SLACK_WEBHOOK_URL: https://hooks.slack.com/services/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

  notify-production-slack:
    needs: [deploy-production, rolling-average]
    runs-on: ubuntu-latest
    steps:
      - name: Notify Slack
        run: |
          curl -X POST -H 'Content-type: application/json' \
          --data '{
            "text": "🚀 Production deploy completed in ${{ needs.deploy-production.outputs.deploy_duration }}s (avg last 5: ${{ needs.rolling-average.outputs.rolling_avg }}s)"
          }' \
          https://hooks.slack.com/services/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

  notify-production-teams:
    needs: [deploy-production, rolling-average]
    runs-on: ubuntu-latest
    steps:
      - name: Notify Teams
        run: |
          curl -H 'Content-Type: application/json' \
          -d '{
            "@type": "MessageCard",
            "@context": "http://schema.org/extensions",
            "summary": "Production Deployment",
            "themeColor": "00CC66",
            "title": "🚀 Production deployment completed",
            "sections": [{
              "facts": [
                { "name": "Duration", "value": "${{ needs.deploy-production.outputs.deploy_duration }}s" },
                { "name": "Rolling Avg (last 5)", "value": "${{ needs.rolling-average.outputs.rolling_avg }}s" },
                { "name": "Workflow Run", "value": "https://github.com/${{ github.repository }}/actions/runs/${{ github.run_id }}" }
              ]
            }]
          }' \
          ${{ secrets.TEAMS_WEBHOOK_URL }}
